API_ENABLED=true
PORT=3000

MONGODB_URI=mongodb://admin:secret@mongodb:27017/roseman?authSource=admin

# Docker Compose variables (used by docker-compose.yml)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=secret
MONGO_VERSION=8

ROBONOMICS_ACCOUNTS="4HMPh33CSbyt5fjDQeaHv4V7TRUKycKx4Q8vBGAekq49rm14,4D23jonvAPrHCGkEHN1VJ4LsRzZ1DkS7cwpjkM5HKe3bWUmm,4DWazwmmeUfs7PJz4NUdwFJoiyLsz71WMA44RruYuibBbHZL"

INDEXER_ENABLED=false
MEASUREMENT_ENABLED=false
GEOCODING_ENABLED=false

# Фильтрация хендлеров индексатора (опционально).
# Доступные имена: datalog-new-record, rws-new-devices, rws-extrinsic, rws-story
# ENABLED_HANDLERS — allowlist (через запятую). Если задан — включаются только перечисленные.
# DISABLED_HANDLERS — denylist. Применяется поверх allowlist.
# Если обе переменные пустые — включены все хендлеры.
#ENABLED_HANDLERS=datalog-new-record,rws-new-devices,rws-extrinsic,rws-story
#DISABLED_HANDLERS=rws-story

# ROBONOMICS_START_BLOCK — номер блока или `latest` (текущий блок чейна). По умолчанию `latest`
# Используется только при первом запуске (или если ROBONOMICS_START_BLOCK_FORCE=true).
#ROBONOMICS_START_BLOCK=latest
# ROBONOMICS_START_BLOCK_FORCE — принудительно начать с ROBONOMICS_START_BLOCK,
# игнорируя сохранённый в БД блок. По умолчанию false. Не забудьте выключить после запуска.
#ROBONOMICS_START_BLOCK_FORCE=false
