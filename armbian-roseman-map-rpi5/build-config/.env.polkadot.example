API_ENABLED=false

ROBONOMICS_WS=wss://polkadot.rpc.robonomics.network
ROBONOMICS_STATE_KEY=polkadot_robonomics
ROBONOMICS_START_BLOCK=latest # Используется только при первом запуске. Номер блока или `latest` (текущий блок чейна). По умолчанию `latest`

INDEXER_ENABLED=true
ENABLED_HANDLERS=datalog-new-record,rws-new-devices,rws-extrinsic,rws-story

IPFS_GATEWAYS=https://plum-relevant-hamster-134.mypinata.cloud/ipfs/,https://ipfs.url.today/ipfs/
IPFS_FETCH_TIMEOUT=30000
IPFS_POLL_INTERVAL=10000

MEASUREMENT_ENABLED=true
GEOCODING_ENABLED=true
