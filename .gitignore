# =============================================================
# Armbian RoSeMAN + Map — .gitignore
# =============================================================

# Armbian build system (auto-cloned by build.sh)
armbian-build/

# Docker image tars (generated by prepare-docker-images.sh)
# ~1.2 GB each, pulled from ghcr.io
*-arm64.tar

# Built Armbian images (generated by build.sh)
*.img
*.img.xz
*.img.sha
*.img.txt

# Built sensors.social SPA (generated by build-map.sh)
# ~37 MB, cloned from github.com/airalab/sensors.social
armbian-roseman-map-*/overlay/var/www/sensors-social/*
# But keep .gitkeep
!armbian-roseman-map-*/overlay/var/www/sensors-social/.gitkeep

# RoSeMAN source files (generated by sync-roseman.sh)
# Cloned from github.com/falconexe/RoSeMAN
armbian-roseman-map-*/overlay/opt/roseman/src/
armbian-roseman-map-*/overlay/opt/roseman/config/
armbian-roseman-map-*/overlay/opt/roseman/package.json
armbian-roseman-map-*/overlay/opt/roseman/package-lock.json
armbian-roseman-map-*/overlay/opt/roseman/Dockerfile
armbian-roseman-map-*/overlay/opt/roseman/.dockerignore
armbian-roseman-map-*/overlay/opt/roseman/nest-cli.json
armbian-roseman-map-*/overlay/opt/roseman/tsconfig.json
armbian-roseman-map-*/overlay/opt/roseman/tsconfig.build.json
armbian-roseman-map-*/overlay/opt/roseman/.env.example
armbian-roseman-map-*/overlay/opt/roseman/.env.polkadot.example

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/
